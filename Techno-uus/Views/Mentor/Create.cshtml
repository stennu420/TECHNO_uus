@model Techno_uus.Models.Mentor

@{
    ViewData["Title"] = "Uus Mentor";
}

<h1>Lisa uus Mentor</h1>
<form asp-action="Create">

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-asp-for="FirstName" class="control-label">Eesnimi</label>
        <input asp-for="FirstName" class="form-control" />
        <span asp-asp-validation-for="FirstName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-asp-for="LastName" class="control-label">Perokonna nimi</label>
        <input asp-for="LastName" class="form-control" />
        <span asp-asp-validation-for="LastName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-asp-for="PersonalCode" class="control-label">Id</label>
        <input asp-for="PersonalCode" class="form-control" />
        <span asp-asp-validation-for="PersonalCode" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-asp-for="Email" class="control-label">Email</label>
        <input asp-for="Email" class="form-control" />
        <span asp-asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-asp-for="PhoneNumber" class="control-label">Telefoni number</label>
        <input asp-for="PhoneNumber" class="form-control" />
        <span asp-asp-validation-for="PhoneNumber" class="text-danger"></span>
    </div>

    

    <div class="container">
        <div class="mb-2">
            <label asp-for="IsFired" class="form-label">
                Kas on vallandatud
            </label>
            <div class="form-check">
                <input class="form-check-input" type="checkbox" asp-for="IsFired" />
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-success">Salvesta</button>
    <a asp-action="Index" class="btn btn-secondary">Tagasi</a>

</form>

