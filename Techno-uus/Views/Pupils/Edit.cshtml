@model Techno_uus.Models.Pupil

<h1>Muuda Juntsu</h1>
<form asp-action="Edit">
	<div asp-validation-summary="ModelOnly" class="text-danger"></div>


	<div class="form-group">
		<label asp-for="FirstName" ˇclass="control-label"></label>
		<input asp-for="FirstName" class="form-control" />
		<span asp-validation-for="FirstName" class="text-danger"></span>
	</div>

	<div class="form-group">
		<label asp-for="LastName" ˇclass="control-label"></label>
		<input asp-for="LastName" class="form-control" />
		<span asp-validation-for="LastName" class="text-danger"></span>
	</div>

	<div class="form-group">
		<label asp-for="HasEnrolleddAt" ˇclass="control-label"></label>
		<input asp-for="HasEnrolleddAt" class="form-control" />
		<span asp-validation-for="HasEnrolleddAt" class="text-danger"></span>
	</div>

	<div class="form-group">
		<label asp-for="DayOfBirth" ˇclass="control-label"></label>
		<input asp-for="DayOfBirth" class="form-control" />
		<span asp-validation-for="DayOfBirth" class="text-danger"></span>
	</div>

	<div class="form-group">
		<label asp-for="PhoneNumber" ˇclass="control-label"></label>
		<input asp-for="PhoneNumber" class="form-control" />
		<span asp-validation-for="PhoneNumber" class="text-danger"></span>
	</div>

	<div class="form-group">
		<label asp-for="PostCode" ˇclass="control-label"></label>
		<input asp-for="PostCode" class="form-control" />
		<span asp-validation-for="PostCode" class="text-danger"></span>
	</div>

	<div class="form-group">
		<label asp-for="Grade" class="col-sm-2 col-form-label"></label>
		<div class="col-sm-10">
			<select asp-for="Grade" asp-items="Html.GetEnumSelectList<EducationLevel>()">
				<option value="">@Html.DisplayNameFor(mdl => mdl.Grade)</option>
			</select>
			<span asp-validation-for="Grade"></span>
		</div>
	</div>

	<form asp-action="Edit">
		<input type="hidden" asp-for="Id" />
		<input type="submit" value="Muuda Õpilane" class="btn btn-danger" /> <br />
		<a asp-action="Index">Tühista</a>
	</form>

</form>
